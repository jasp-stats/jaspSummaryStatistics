msgctxt "SummaryStatsTestStatistics|"
msgid "Use for comparing variances or in ANOVA"
msgstr "Gunakan untuk membandingkan varians atau di ANOVA"

msgctxt "SummaryStatsTestStatistics|"
msgid "Enter the calculated F-statistic value"
msgstr "Masukkan nilai statistik-F terhitung"

msgctxt "SummaryStatsTestStatistics|"
msgid "Numerator df:"
msgstr "df Numerator:"

msgctxt "SummaryStatsTestStatistics|"
msgid "Enter the numerator degrees of freedom"
msgstr "Masukkan derajat kebebasan numerator"

msgctxt "SummaryStatsTestStatistics|"
msgid "Denominator df:"
msgstr "df Denominator:"

msgctxt "SummaryStatsTestStatistics|"
msgid "Enter the denominator degrees of freedom"
msgstr "Masukkan derajat kebebasan denominator"

msgctxt "SummaryStatsTestStatistics|"
msgid "Alternative Hypothesis"
msgstr "Hipotesis Alternatif"

msgctxt "SummaryStatsTestStatistics|"
msgid ""
"Choose the direction of the alternative hypothesis for directional tests"
msgstr "Pilih arahan dari hipotesis alternatif untuk uji terarah"

msgctxt "SummaryStatsTestStatistics|"
msgid "Two-sided"
msgstr "Dua sisi"

msgctxt "SummaryStatsTestStatistics|"
msgid "Test if the parameter differs from the null value in either direction"
msgstr "Uji jika parameter berbeda dari nilai null di kedua arah"

msgctxt "SummaryStatsTestStatistics|"
msgid "Greater"
msgstr "Lebih"

msgctxt "SummaryStatsTestStatistics|"
msgid "Test if the parameter is greater than the null value"
msgstr "Uji jika parameter lebih dari nilai null"

msgctxt "SummaryStatsTestStatistics|"
msgid "Less"
msgstr "Kurang"

msgctxt "SummaryStatsTestStatistics|"
msgid "Test if the parameter is less than the null value"
msgstr "Uji jika parameter kurang dari nilai null"
