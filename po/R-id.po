msgid "For all tests, the alternative hypothesis specifies that group 1 is greater than group 2."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa grup 1 lebih dari "
"grup 2."

msgid "For all tests, the alternative hypothesis specifies that the mean is greater than 0."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa rerata lebih dari 0."

msgid "For all tests, the alternative hypothesis specifies that measure 1 is greater than measure 2."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa pengukuran 1 lebih "
"dari pengukuran 2."

msgid "For all tests, the alternative hypothesis specifies that group 1 is less than group 2."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa grup 1 kurang dari "
"grup 2."

msgid "For all tests, the alternative hypothesis specifies that the mean is less than 0."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa rerata kurang dari 0."

msgid "For all tests, the alternative hypothesis specifies that measure 1 is less than measure 2."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa pengukuran 1 kurang "
"dari pengukuran 2."

