msgstr ""
"Pendiagraman tidak memungkinkan: Tidak dapat mengevaluasi kepadatan priori "
"atau posterior!"

msgid "Proportions tested against value: %s."
msgstr "Proporsi diuji terhadap nilai: %s."

msgid "For all tests, the alternative hypothesis specifies that the proportion is greater than %s."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa proporsi lebih dari "
"%s."

msgid "For all tests, the alternative hypothesis specifies that the proportion is less than %s."
msgstr ""
"Untuk semua uji, hipotesis alternatif menentukan bahwa proporsi kurang dari "
"%s."

msgid "Cannot test the hypothesis that the test value is greater than 1."
msgstr "Tidak dapat menguji hipotesis yang nilai uji lebih dari 1."

msgid "Cannot test the hypothesis that the test value is less than 0."
msgstr "Tidak dapat menguji hipotesis yang nilai uji kurang dari 0."

msgid "Undefined hypothesis"
msgstr "Hipotesis tidak ditentukan"

